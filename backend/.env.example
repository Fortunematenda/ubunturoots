# =========================
# SafeCircle Backend (.env)
# =========================

# App
PORT=4000
NODE_ENV=development

# Frontend (used later for CORS / links)
FRONTEND_URL=http://localhost:3000

# CORS
# Use * for local dev, or comma-separated origins in production
# Example: CORS_ORIGINS=http://localhost:3001,https://admin.safecircle.app
CORS_ORIGINS=*

# =========================
# Database (PostgreSQL)
# =========================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=Action15
DB_NAME=ubunturoots

# Optional: if provided, this overrides the DB_* variables above
DATABASE_URL=postgresql://postgres:Action15@localhost:5432/ubunturoots?schema=public

# =========================
# Auth (Phase 2)
# =========================
JWT_SECRET=change-me-change-me
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-too-change-me
JWT_REFRESH_EXPIRES_IN=7d

SEED_ADMIN_PHONE=+27612685933
SEED_ADMIN_PASSWORD=Rachfort24
SEED_DRIVER_PHONE=+27612685932
SEED_DRIVER_PASSWORD=Rachfort24
SEED_CLIENT_PHONE = +27612685931
SEED_CLIENT_PASSWORD = Rachfort24
npm run seed:users

REDIS_URL=redis://127.0.0.1:6379
DRIVER_ONLINE_TTL_SECONDS=30
